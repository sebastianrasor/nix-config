#!/usr/bin/env nix
#! nix shell --quiet --inputs-from . nixpkgs#bash --command bash
# vim: ft=bash

old_dir="$(git rev-parse --absolute-git-dir)"
new_dir="$(mktemp -d)"
trap 'rm -rf -- "$new_dir"' EXIT

git clone "$old_dir" "$new_dir"
unset "$(git rev-parse --local-env-vars)"

cd "$new_dir" || exit 1

nix flake check

